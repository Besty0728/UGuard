{
  "name": "uguard",
  "version": "0.1.0",
  "private": true,
  "description": "Unity 应用授权管理平台 — EdgeOne Pages + KV",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node dev-server.mjs",
    "dev:all": "concurrently -n server,app -c blue,green \"node dev-server.mjs\" \"vite\"",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.12.4",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9.16.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.13.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.3"
  }
}
